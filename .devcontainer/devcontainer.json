{
	"name": "My Devcontainer",
	"image": "ghcr.io/hilmoo/containers/my-devcontainer:v0.3.0",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"moby": "false"
		},
		"ghcr.io/itsmechlark/features/postgresql:1": {
			"version": "18"
		}
	},
	"customizations": {
		"vscode": {
			"settings": {
				"json.schemaDownload.trustedDomains": {
					"https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json": true
				}
			},
			"extensions": [
				"ms-python.python",
				"golang.go",
				"jetpack-io.devbox",
				"mkhl.direnv",
				"42Crunch.vscode-openapi",
				"redhat.vscode-yaml"
			]
		}
	},
	"remoteUser": "vscode",
	"postCreateCommand": ".devcontainer/post-create.sh"
}