{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "air@1.63.0",
    "go@1.26.0",
    "uv@0.10.6",
    "nodejs@24.12.0",
    "pnpm@10.29.2",
    "goose@3.26.0",
    "sqlc@1.30.0"
  ],
  "shell": {
    "init_hook": [
      "export \"GOROOT=$(go env GOROOT)\"",
      "export PATH=$PATH:$(go env GOPATH)/bin"
    ]
  },
  "env_from": ".env"
}
