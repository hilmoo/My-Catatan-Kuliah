openapi: 3.0.1
info:
  title: Course Management API
  version: 1.0.0
paths:
  /assignments:
    get:
      summary: List assignments for a course
      parameters:
        - name: page
          in: query
          description: Page number (1-based)
          schema:
            type: integer
            default: 1
            minimum: 1
        - name: limit
          in: query
          description: Number of items per page
          schema:
            type: integer
            default: 20
            maximum: 100
            minimum: 1
        - name: sort
          in: query
          schema:
            type: string
            default: deadline
            enum:
              - id
              - title
              - deadline
              - status
              - created_at
              - updated_at
        - name: order
          in: query
          schema:
            type: string
            default: asc
            enum:
              - asc
              - desc
        - name: status
          in: query
          schema:
            $ref: '#/components/schemas/AssignmentStatus'
        - name: created_by
          in: query
          schema:
            type: integer
        - name: deadline_before
          in: query
          schema:
            type: string
            format: date-time
        - name: deadline_after
          in: query
          schema:
            type: string
            format: date-time
      responses:
        '200':
          description: Paginated list of assignments
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssignmentListResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Assignments
        - Assignments
    post:
      summary: Create an assignment for a course
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AssignmentCreateRequest'
            example:
              title: Problem Set 1
              description: Solve exercises 1–10 from Chapter 2.
              deadline: '2026-04-01T23:59:00Z'
              status: pending
      responses:
        '201':
          description: Assignment created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssignmentResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Assignments
        - Assignments
  '/assignments/{assignmentId}':
    get:
      summary: Get an assignment by ID
      parameters:
        - name: assignmentId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '200':
          description: Assignment found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssignmentResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Assignments
        - Assignments
    patch:
      summary: Update an assignment
      parameters:
        - name: assignmentId
          in: path
          required: true
          schema:
            type: string
          example: ''
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/AssignmentUpdateRequest'
            example:
              status: in_progress
              deadline: '2026-04-05T23:59:00Z'
      responses:
        '200':
          description: Updated assignment
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AssignmentResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Assignments
        - Assignments
    delete:
      summary: Delete an assignment
      parameters:
        - name: assignmentId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '204':
          description: Assignment deleted
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Assignments
        - Assignments
  /auth/register:
    post:
      summary: Register a new user
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserRegisterRequest'
      responses:
        '201':
          description: User registered
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '409':
          description: Unique constraint violation
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      security: []
      tags:
        - Auth
  /auth/login:
    post:
      summary: Log in and receive a session cookie
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LoginRequest'
      responses:
        '200':
          description: Authenticated – session cookie is set
          headers:
            Set-Cookie:
              description: 'Session cookie (HttpOnly, Secure, SameSite=Lax)'
              schema:
                type: string
                example: session=abc123; Path=/; HttpOnly; Secure; SameSite=Lax
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      security: []
      tags:
        - Auth
  /auth/logout:
    post:
      summary: Log out and invalidate the session
      responses:
        '204':
          description: Logged out
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Auth
  /auth/me:
    get:
      summary: Return the currently authenticated user
      responses:
        '200':
          description: Current user
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Auth
  /notes:
    get:
      summary: List notes for a course
      parameters:
        - name: page
          in: query
          description: Page number (1-based)
          schema:
            type: integer
            default: 1
            minimum: 1
        - name: limit
          in: query
          description: Number of items per page
          schema:
            type: integer
            default: 20
            maximum: 100
            minimum: 1
        - name: sort
          in: query
          schema:
            type: string
            default: created_at
            enum:
              - id
              - title
              - created_at
              - updated_at
        - name: order
          in: query
          schema:
            type: string
            default: desc
            enum:
              - asc
              - desc
        - name: title
          in: query
          description: Filter by title (partial match)
          schema:
            type: string
        - name: created_by
          in: query
          description: Filter by creator user ID
          schema:
            type: integer
        - name: created_after
          in: query
          schema:
            type: string
            format: date-time
        - name: created_before
          in: query
          schema:
            type: string
            format: date-time
        - name: updated_after
          in: query
          schema:
            type: string
            format: date-time
      responses:
        '200':
          description: Paginated list of course notes
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseNoteListResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Course Notes
        - Course Notes
    post:
      summary: Create a note for a course
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CourseNoteCreateRequest'
            example:
              title: Week 1 Notes
              content: Today we covered Big-O notation.
      responses:
        '201':
          description: Note created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseNoteResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Course Notes
        - Course Notes
  '/notes/{noteId}':
    get:
      summary: Get a course note by ID
      parameters:
        - name: noteId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '200':
          description: Note found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseNoteResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Course Notes
        - Course Notes
    patch:
      summary: Update a course note
      parameters:
        - name: noteId
          in: path
          required: true
          schema:
            type: string
          example: ''
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CourseNoteUpdateRequest'
            example:
              title: Week 1 Notes (revised)
              content: Covers Big-O and Omega notation.
      responses:
        '200':
          description: Updated note
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseNoteResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Course Notes
        - Course Notes
    delete:
      summary: Delete a course note
      parameters:
        - name: noteId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '204':
          description: Note deleted
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Course Notes
        - Course Notes
  '/workspaces/{workspaceId}/courses':
    get:
      summary: List courses in a workspace
      parameters:
        - name: workspaceId
          in: path
          required: true
          schema:
            type: string
          example: ''
        - name: page
          in: query
          description: Page number (1-based)
          schema:
            type: integer
            default: 1
            minimum: 1
        - name: limit
          in: query
          description: Number of items per page
          schema:
            type: integer
            default: 20
            maximum: 100
            minimum: 1
        - name: sort
          in: query
          schema:
            type: string
            default: id
            enum:
              - id
              - name
              - day
              - start_time
        - name: order
          in: query
          schema:
            type: string
            default: asc
            enum:
              - asc
              - desc
        - name: day
          in: query
          description: Filter by day of week
          schema:
            $ref: '#/components/schemas/DayOfWeek'
        - name: name
          in: query
          description: Filter by course name (partial match)
          schema:
            type: string
        - name: lecturer_name
          in: query
          description: Filter by lecturer name (partial match)
          schema:
            type: string
      responses:
        '200':
          description: Paginated list of courses
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseListResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Courses
        - Courses
  /courses:
    post:
      summary: Create a course in a workspace
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CourseCreateRequest'
            example:
              name: Introduction to Algorithms
              lecturer_name: Dr. Smith
              day: monday
              start_time: '09:00:00'
              end_time: '10:30:00'
      responses:
        '201':
          description: Course created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Courses
        - Courses
    get:
      summary: List all courses (across all workspaces)
      parameters:
        - name: page
          in: query
          description: Page number (1-based)
          schema:
            type: integer
            default: 1
            minimum: 1
        - name: limit
          in: query
          description: Number of items per page
          schema:
            type: integer
            default: 20
            maximum: 100
            minimum: 1
        - name: workspace_id
          in: query
          schema:
            type: integer
        - name: day
          in: query
          schema:
            $ref: '#/components/schemas/DayOfWeek'
        - name: sort
          in: query
          schema:
            type: string
            default: id
            enum:
              - id
              - name
              - day
              - start_time
        - name: order
          in: query
          schema:
            type: string
            default: asc
            enum:
              - asc
              - desc
      responses:
        '200':
          description: Paginated list of courses
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseListResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Courses
        - Courses
  '/courses/{courseId}':
    get:
      summary: Get a course by ID
      parameters:
        - name: courseId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '200':
          description: Course found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Courses
        - Courses
    patch:
      summary: Update a course
      parameters:
        - name: courseId
          in: path
          required: true
          schema:
            type: string
          example: ''
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CourseUpdateRequest'
            example:
              day: tuesday
              start_time: '10:00:00'
              end_time: '11:30:00'
      responses:
        '200':
          description: Updated course
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CourseResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Courses
        - Courses
    delete:
      summary: Delete a course
      parameters:
        - name: courseId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '204':
          description: Course deleted
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Courses
        - Courses
  /users:
    get:
      summary: List all users
      parameters:
        - name: page
          in: query
          description: Page number (1-based)
          schema:
            type: integer
            default: 1
            minimum: 1
        - name: limit
          in: query
          description: Number of items per page
          schema:
            type: integer
            default: 20
            maximum: 100
            minimum: 1
        - name: sort
          in: query
          schema:
            type: string
            default: id
            enum:
              - id
              - username
              - email
              - created_at
        - name: order
          in: query
          schema:
            type: string
            default: asc
            enum:
              - asc
              - desc
        - name: username
          in: query
          description: Filter by username (partial match)
          schema:
            type: string
        - name: email
          in: query
          description: Filter by email (partial match)
          schema:
            type: string
      responses:
        '200':
          description: Paginated list of users
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserListResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Users
        - Users
  '/users/{userId}':
    get:
      summary: Get a user by ID
      parameters:
        - name: userId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '200':
          description: User found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Users
        - Users
    patch:
      summary: Update a user
      parameters:
        - name: userId
          in: path
          required: true
          schema:
            type: string
          example: ''
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserUpdateRequest'
            example:
              username: janedoe
              email: jane@example.com
      responses:
        '200':
          description: Updated user
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '409':
          description: Unique constraint violation
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
              example:
                error: conflict
                message: A user with that email already exists.
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Users
        - Users
    delete:
      summary: Delete a user
      parameters:
        - name: userId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '204':
          description: User deleted
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Users
        - Users
  /workspaces:
    get:
      summary: List workspaces
      parameters:
        - name: page
          in: query
          description: Page number (1-based)
          schema:
            type: integer
            default: 1
            minimum: 1
        - name: limit
          in: query
          description: Number of items per page
          schema:
            type: integer
            default: 20
            maximum: 100
            minimum: 1
        - name: sort
          in: query
          schema:
            type: string
            default: id
            enum:
              - id
              - name
              - created_at
        - name: order
          in: query
          schema:
            type: string
            default: asc
            enum:
              - asc
              - desc
        - name: name
          in: query
          description: Filter by workspace name (partial match)
          schema:
            type: string
        - name: owner_id
          in: query
          description: Filter by owner user ID
          schema:
            type: integer
      responses:
        '200':
          description: Paginated list of workspaces
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorkspaceListResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Workspaces
        - Workspaces
    post:
      summary: Create a workspace
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WorkspaceCreateRequest'
            example:
              name: My Workspace
              owner_id: 1
      responses:
        '201':
          description: Workspace created
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorkspaceResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Workspaces
        - Workspaces
  '/workspaces/{workspaceId}':
    get:
      summary: Get a workspace by ID
      parameters:
        - name: workspaceId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '200':
          description: Workspace found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorkspaceResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Workspaces
        - Workspaces
    patch:
      summary: Update a workspace
      parameters:
        - name: workspaceId
          in: path
          required: true
          schema:
            type: string
          example: ''
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WorkspaceUpdateRequest'
            example:
              name: Renamed Workspace
      responses:
        '200':
          description: Updated workspace
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WorkspaceResponse'
        '400':
          description: Invalid request body or parameters
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Workspaces
        - Workspaces
    delete:
      summary: Delete a workspace
      parameters:
        - name: workspaceId
          in: path
          required: true
          schema:
            type: string
          example: ''
      responses:
        '204':
          description: Workspace deleted
        '401':
          description: Missing or invalid session cookie
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '404':
          description: Resource not found
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        '500':
          description: Internal server error
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
      tags:
        - Workspaces
        - Workspaces
components:
  schemas:
    DayOfWeek:
      type: string
      enum:
        - monday
        - tuesday
        - wednesday
        - thursday
        - friday
        - saturday
        - sunday
    AssignmentStatus:
      type: string
      enum:
        - pending
        - in_progress
        - submitted
        - graded
        - overdue
    PaginationMeta:
      type: object
      properties:
        page:
          type: integer
          examples: 1
        limit:
          type: integer
          example: 20
        total:
          type: integer
          example: 42
        totalPages:
          type: integer
          example: 3
      required:
        - page
        - limit
        - total
        - totalPages
    ErrorResponse:
      type: object
      properties:
        id:
          type: string
          example: 123e4567-e89b-12d3-a456-426614174000
        reason:
          type: string
          example: Not Found
        status:
          type: string
          example: The requested resource could not be found.
        error:
          type: string
          example: not_found
        code:
          type: integer
          example: 404
        details:
          type: object
          example:
            resource: User
            id: 999
          additionalProperties: true
          properties: {}
      required:
        - id
        - reason
        - status
        - error
        - code
        - details
    UserResponse:
      type: object
      properties:
        id:
          type: string
          example: 'ATaXCBB52XSTcJi4aWp9j'
        username:
          type: string
          example: johndoe
        email:
          type: string
          format: email
          example: john@example.com
      required:
        - id
        - username
        - email
        - createdAt
    UserRegisterRequest:
      type: object
      properties:
        username:
          type: string
          example: johndoe
          maxLength: 50
          minLength: 3
        email:
          type: string
          format: email
          example: john@example.com
        password:
          type: string
          format: password
          example: s3cr3tP@ss
          minLength: 8
      required:
        - username
        - email
        - password
    UserUpdateRequest:
      type: object
      properties:
        username:
          type: string
          maxLength: 50
          minLength: 3
        email:
          type: string
          format: email
        password:
          type: string
          format: password
          minLength: 8
      minProperties: 1
    LoginRequest:
      type: object
      properties:
        email:
          type: string
          format: email
          example: john@example.com
        password:
          type: string
          format: password
          example: s3cr3tP@ss
      required:
        - email
        - password
    UserListResponse:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: '#/components/schemas/UserResponse'
        meta:
          $ref: '#/components/schemas/PaginationMeta'
      required:
        - data
        - meta
    WorkspaceResponse:
      type: object
      properties:
        id:
          type: integer
          example: 10
        name:
          type: string
          example: CS 2026
        ownerId:
          description: ID of the owning user
          type: integer
          example: 1
        owner:
          $ref: '#/components/schemas/UserResponse'
        createdAt:
          type: string
          format: date-time
          example: '2026-01-20T09:00:00Z'
      required:
        - id
        - name
        - ownerId
        - createdAt
    WorkspaceCreateRequest:
      type: object
      properties:
        name:
          type: string
          example: CS 2026
          maxLength: 255
          minLength: 1
        ownerId:
          type: integer
          example: 1
      required:
        - name
        - ownerId
    WorkspaceUpdateRequest:
      type: object
      properties:
        name:
          type: string
          maxLength: 255
          minLength: 1
      minProperties: 1
    WorkspaceListResponse:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: '#/components/schemas/WorkspaceResponse'
        meta:
          $ref: '#/components/schemas/PaginationMeta'
      required:
        - data
        - meta
    CourseResponse:
      type: object
      properties:
        id:
          type: integer
          example: 5
        name:
          type: string
          example: Introduction to Algorithms
        lecturerName:
          type: string
          example: Dr. Smith
          nullable: true
        day:
          $ref: '#/components/schemas/DayOfWeek'
        startTime:
          type: string
          format: time
          example: '09:00:00'
        endTime:
          type: string
          format: time
          example: '10:30:00'
        workspaceId:
          type: integer
          example: 10
        workspace:
          $ref: '#/components/schemas/WorkspaceResponse'
      required:
        - id
        - name
        - day
        - startTime
        - endTime
        - workspaceId
    CourseCreateRequest:
      type: object
      properties:
        name:
          type: string
          example: Introduction to Algorithms
          maxLength: 255
          minLength: 1
        lecturerName:
          type: string
          example: Dr. Smith
          nullable: true
        day:
          $ref: '#/components/schemas/DayOfWeek'
        startTime:
          type: string
          format: time
          example: '09:00:00'
        endTime:
          description: Must be after start_time
          type: string
          format: time
          example: '10:30:00'
      required:
        - name
        - day
        - startTime
        - endTime
    CourseUpdateRequest:
      type: object
      properties:
        name:
          type: string
          maxLength: 255
          minLength: 1
        lecturerName:
          type: string
          nullable: true
        day:
          $ref: '#/components/schemas/DayOfWeek'
        startTime:
          type: string
          format: time
        endTime:
          description: Must be after start_time
          type: string
          format: time
      minProperties: 1
    CourseListResponse:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: '#/components/schemas/CourseResponse'
        meta:
          $ref: '#/components/schemas/PaginationMeta'
      required:
        - data
        - meta
    CourseNoteResponse:
      type: object
      properties:
        id:
          type: integer
          example: 100
        title:
          type: string
          example: Week 1 Notes
        content:
          example: Today we covered Big-O notation.
          nullable: true
          type: string
        contentBlobUrl:
          description: |
            Presigned URL to download the binary content blob. Null when no blob is stored.
          type: string
          format: uri
          example: 'https://storage.example.com/notes/100/blob?token=xyz'
          nullable: true
        courseId:
          type: integer
          example: 5
        createdBy:
          type: integer
          example: 1
        author:
          $ref: '#/components/schemas/UserResponse'
        createdAt:
          type: string
          format: date-time
          example: '2026-02-01T10:00:00Z'
        updatedAt:
          type: string
          format: date-time
          example: '2026-02-05T14:30:00Z'
      required:
        - id
        - title
        - courseId
        - createdBy
        - createdAt
        - updatedAt
    CourseNoteCreateRequest:
      type: object
      properties:
        title:
          type: string
          example: Week 1 Notes
          maxLength: 500
          minLength: 1
        content:
          example: Today we covered Big-O notation.
          nullable: true
          type: string
      required:
        - title
    CourseNoteUpdateRequest:
      type: object
      properties:
        title:
          type: string
          maxLength: 500
          minLength: 1
        content:
          nullable: true
          type: string
      minProperties: 1
    CourseNoteListResponse:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: '#/components/schemas/CourseNoteResponse'
        meta:
          $ref: '#/components/schemas/PaginationMeta'
      required:
        - data
        - meta
    AssignmentResponse:
      type: object
      properties:
        id:
          type: integer
          example: 20
        title:
          type: string
          example: Problem Set 1
        description:
          type: string
          example: Solve exercises 1–10 from Chapter 2.
          nullable: true
        deadline:
          type: string
          format: date-time
          example: '2026-04-01T23:59:00Z'
        status:
          $ref: '#/components/schemas/AssignmentStatus'
        courseId:
          type: integer
          example: 5
        createdBy:
          type: integer
          example: 1
        author:
          $ref: '#/components/schemas/UserResponse'
        createdAt:
          type: string
          format: date-time
          example: '2026-03-01T08:00:00Z'
        updatedAt:
          type: string
          format: date-time
          example: '2026-03-10T12:00:00Z'
      required:
        - id
        - title
        - deadline
        - status
        - courseId
        - createdBy
        - createdAt
        - updatedAt
    AssignmentCreateRequest:
      type: object
      properties:
        title:
          type: string
          example: Problem Set 1
          maxLength: 500
          minLength: 1
        description:
          type: string
          example: Solve exercises 1–10 from Chapter 2.
          nullable: true
        deadline:
          type: string
          format: date-time
          example: '2026-04-01T23:59:00Z'
        status:
          $ref: '#/components/schemas/AssignmentStatus'
      required:
        - title
        - deadline
    AssignmentUpdateRequest:
      type: object
      properties:
        title:
          type: string
          maxLength: 500
          minLength: 1
        description:
          type: string
          nullable: true
        deadline:
          type: string
          format: date-time
        status:
          $ref: '#/components/schemas/AssignmentStatus'
      minProperties: 1
    AssignmentListResponse:
      type: object
      properties:
        data:
          type: array
          items:
            $ref: '#/components/schemas/AssignmentResponse'
        meta:
          $ref: '#/components/schemas/PaginationMeta'
      required:
        - data
        - meta
  securitySchemes:
    cookieAuth:
      type: apiKey
      name: session
      in: cookie
tags:
  - name: Auth
  - name: Users
  - name: Workspaces
  - name: Courses
  - name: Course Notes
  - name: Assignments
security:
  - cookieAuth: []
